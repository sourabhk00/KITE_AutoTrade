# ============================================================
#  .env  —  Zerodha Bot Configuration
#  STEP 1: Copy this file:   copy .env.example .env  (Windows)
#                            cp .env.example .env    (Mac/Linux)
#  STEP 2: Fill in your KITE_API_KEY and KITE_API_SECRET below
#  STEP 3: Save the file, then run: python login.py
# ============================================================

# ── Zerodha Kite API keys ─────────────────────────────────
# Get from: https://developers.kite.trade
# Click "My Apps" → create an app → copy API Key and API Secret
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# ── News API (optional, free) ─────────────────────────────
# Get free key: https://newsapi.org (100 calls/day free)
NEWSAPI_KEY=

# ── Telegram alerts (optional) ───────────────────────────
# Create a bot: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading mode ──────────────────────────────────────────
PAPER_TRADING=true

# ── Dashboard port ────────────────────────────────────────
DASHBOARD_PORT=8050
DASHBOARD_HOST=127.0.0.1
